{
  "name": "remote-qt-designer",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "publisher": "specialtiger",
  "repository": {
    "type": "git",
    "url": "https://github.com/specialtiger/remote-qt-designer.git"
  },
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.60.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:remote-qt-designer.openLocal",
    "onCommand:remote-qt-designer.openLinguist",
    "onCommand:remote-qt-designer.openQmlscene"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remote-qt-designer.openLocal",
        "title": "%command.openLocal%"
      },
      {
        "command": "remote-qt-designer.openLinguist",
        "title": "%command.openLinguist%"
      },
      {
        "command": "remote-qt-designer.openQmlscene",
        "title": "%command.openQmlscene%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "remote-qt-designer.openLocal",
          "when": "resourceExtname == .ui",
          "group": "navigation"
        },
        {
          "command": "remote-qt-designer.openLinguist",
          "when": "resourceExtname == .ts",
          "group": "navigation"
        },
        {
          "command": "remote-qt-designer.openQmlscene",
          "when": "resourceExtname == .qml",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "remoteQtDesigner.designerPath": {
          "type": "string",
          "default": "D:\\Qt5.15\\5.15.2\\msvc2019_64\\bin\\designer.exe",
          "description": "%config.designerPath.description%"
        },
        "remoteQtDesigner.linguistPath": {
          "type": "string",
          "default": "D:\\Qt5.15\\5.15.2\\msvc2019_64\\bin\\linguist.exe",
          "description": "%config.linguistPath.description%"
        },
        "remoteQtDesigner.qmlscenePath": {
          "type": "string",
          "default": "D:\\Qt5.15\\5.15.2\\msvc2019_64\\bin\\qmlscene.exe",
          "description": "%config.qmlscenePath.description%"
        }
      }
    }
  }
}